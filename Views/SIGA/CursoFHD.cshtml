@{
    Layout = null;
}

<div class="course-detail-view">
    <h2 class="page-title">Mis asignaturas - <span>FHD</span></h2>

    <a href="#" class="back-link" onclick="goBackToSummary(event)">&lt; Ir al resumen</a>

    <div class="course-header">
        <div class="course-info">
            <h3>HISTORIA DEL DERECHO</h3>
            <div class="info-row">
                <i class="fa-solid fa-user-tie icon-gray"></i>
                <strong>Profesor(a):</strong> <a href="#" class="prof-link">JULIO CÁRDENAS</a>
            </div>
            <div class="info-row">
                <i class="fa-solid fa-table-cells icon-gray"></i>
                <strong>Nro. de alumnos:</strong> 17
            </div>
        </div>
    </div>

    <div class="tabs">
        <button class="tab active">Evaluaciones</button>
        <button class="tab">Material</button>
        <button class="tab">Asistencia</button>
        <button class="tab">Avisos</button>
        <button class="tab">Alumnos</button>
        <button class="tab">Sílabo</button>
    </div>

    <div class="evaluation-section">
        <div class="section-header">Práctica</div>
        <table class="grades-table">
            <thead>
                <tr>
                    <th>Fecha</th>
                    <th>Evaluación</th>
                    <th>Peso</th>
                    <th>Anulable</th>
                    <th>Informativa</th>
                    <th>Estado</th>
                    <th>Nota</th>
                </tr>
            </thead>
            <tbody>
                <tr class="row-fail">
                    <td>01-05-2026</td>
                    <td><a href="#">Práctica 1</a></td>
                    <td>2</td>
                    <td><i class="fa-solid fa-check"></i></td>
                    <td><i class="fa-solid fa-xmark"></i></td>
                    <td>Acta cerrada</td>
                    <td class="grade-fail">08</td>
                </tr>
            </tbody>
        </table>
    </div>
</div>
