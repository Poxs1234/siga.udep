@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SIGA - Dashboard</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/siga.css">
</head>
<body>

    <div class="dashboard-wrapper">
        
        <aside class="sidebar">
            
            <div class="sidebar-header">
                <div class="brand">
                    <strong>UDEP</strong> SIGA
                </div>
                <div class="user-profile">
                    <span class="user-name">ALESSIA MORENO</span>
                    <div class="user-actions">
                        <i class="fa-solid fa-gear"></i>
                        <i class="fa-solid fa-power-off"></i>
                    </div>
                </div>
            </div>

            <nav class="sidebar-menu">
                <ul class="main-menu">
                    <li class="active"><a href="#" data-view="view-avisos"><i class="fa-solid fa-flag menu-icon"></i> Avisos <i class="fa-solid fa-chevron-right arrow"></i></a></li>
                    
                    <li><a href="#" data-view="view-mis-asignaturas"><i class="fa-solid fa-book menu-icon"></i> Mis asignaturas <i class="fa-solid fa-chevron-right arrow"></i></a></li>
                    
                    <li><a href="#"><i class="fa-solid fa-clock menu-icon"></i> Mi horario <i class="fa-solid fa-chevron-right arrow"></i></a></li>
                    <li><a href="#"><i class="fa-solid fa-bookmark menu-icon"></i> Mi perfil académico <i class="fa-solid fa-chevron-right arrow"></i></a></li>
                    <li><a href="#"><i class="fa-solid fa-user menu-icon"></i> Mi perfil personal <i class="fa-solid fa-chevron-right arrow"></i></a></li>
                    <li><a href="#"><i class="fa-solid fa-briefcase menu-icon"></i> Mi asesor <i class="fa-solid fa-chevron-right arrow"></i></a></li>
                    <li><a href="#"><i class="fa-solid fa-barcode menu-icon"></i> Pensiones <i class="fa-solid fa-chevron-right arrow"></i></a></li>
                    <li><a href="#"><i class="fa-solid fa-envelope menu-icon"></i> Mensajería <i class="fa-solid fa-chevron-right arrow"></i></a></li>
                    <li><a href="#"><i class="fa-solid fa-file-lines menu-icon"></i> Trámites académicos <i class="fa-solid fa-chevron-right arrow"></i></a></li>
                    <li><a href="#"><i class="fa-solid fa-globe menu-icon"></i> Intercambio estudiantil <i class="fa-solid fa-chevron-right arrow"></i></a></li>
                    <li><a href="#"><i class="fa-solid fa-building menu-icon"></i> Ambientes <i class="fa-solid fa-chevron-right arrow"></i></a></li>
                    <li><a href="#"><i class="fa-solid fa-cloud-arrow-down menu-icon"></i> Documentos oficiales <i class="fa-solid fa-chevron-right arrow"></i></a></li>
                    <li><a href="#"><i class="fa-solid fa-magnifying-glass menu-icon"></i> Buscar <i class="fa-solid fa-chevron-right arrow"></i></a></li>
                </ul>

                <ul class="bottom-menu">
                    <li><a href="#">Universidad</a></li>
                    <li><a href="#">Mapa de sitio</a></li>
                    <li><a href="#">Reclamos, consultas y sugerencias</a></li>
                    <li><a href="#">Guía de usuario</a></li>
                </ul>
            </nav>
        </aside>

        <main class="main-content">
            <header class="content-header">
                <h1 id="pageTitle">SIGA</h1>
                <div class="loading-badge hidden" id="loadingBadge">
                    <i class="fa-solid fa-rotate"></i> Cargando...
                </div>
            </header>

            <div class="content-body">
                <div id="view-avisos" class="page-view" style="display: block;">
                    @{ await Html.RenderPartialAsync("Avisos"); }
                </div>

                <div id="view-mis-asignaturas" class="page-view" style="display: none;">
                    @{ await Html.RenderPartialAsync("MisAsignaturas"); }
                </div>
            </div>
        </main>

    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const badge = document.getElementById('loadingBadge');
            const links = document.querySelectorAll('.sidebar-menu .main-menu a, .bottom-menu a');
            const views = document.querySelectorAll('.page-view');
            let timeoutId;

            function showView(viewId) {
                const pageTitle = document.getElementById('pageTitle');
                const titles = {
                    'view-avisos': 'AVISOS',
                    'view-mis-asignaturas': 'MIS ASIGNATURAS'
                };

                views.forEach(function (view) {
                    view.style.display = view.id === viewId ? 'block' : 'none';
                });

                document.querySelectorAll('.main-menu li').forEach(function (item) {
                    item.classList.remove('active');
                });

                const activeLink = document.querySelector('.main-menu a[data-view="' + viewId + '"]');
                if (activeLink) {
                    activeLink.closest('li').classList.add('active');
                }

                pageTitle.textContent = titles[viewId] || 'SIGA';
            }

            links.forEach(function (link) {
                link.addEventListener('click', function (event) {
                    if (this.getAttribute('href') === '#') {
                        event.preventDefault();
                    }

                    const viewId = this.getAttribute('data-view');
                    if (viewId) {
                        showView(viewId);
                    }

                    badge.classList.remove('hidden');
                    clearTimeout(timeoutId);
                    timeoutId = setTimeout(function () {
                        badge.classList.add('hidden');
                    }, 2000);
                });
            });

            showView('view-avisos');
        });
        // Función para mostrar el detalle de un curso específico
        function showCourseDetails(courseCode, courseName) {
            const pageTitle = document.getElementById('pageTitle');
            const detailPanels = document.querySelectorAll('.course-detail-panel');

            pageTitle.textContent = 'MIS ASIGNATURAS - ' + courseCode;

            document.getElementById('view-summary').style.display = 'none';
            document.getElementById('view-details').style.display = 'block';

            detailPanels.forEach(function (panel) {
                panel.style.display = 'none';
            });

            const selectedPanel = document.getElementById('course-detail-' + courseCode);
            if (selectedPanel) {
                selectedPanel.style.display = 'block';
            }
        }

        // Función para volver a la lista principal
        function goBackToSummary(event) {
            event.preventDefault(); // Evita que la página salte hacia arriba
            
            const pageTitle = document.getElementById('pageTitle');
            pageTitle.textContent = 'MIS ASIGNATURAS';

            document.querySelectorAll('.course-detail-panel').forEach(function (panel) {
                panel.style.display = 'none';
            });

            document.getElementById('view-details').style.display = 'none';
            document.getElementById('view-summary').style.display = 'block';
        }
    </script>

</body>
</html>